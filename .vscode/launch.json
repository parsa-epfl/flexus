    "version": "0.2.0",
    "configurations": [
        {
            "name": "Flexus Harness",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/testing_harness",
            "args": [
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
              {
                "description": "Enable pretty-printing for gdb",
                "text": "-enable-pretty-printing",
                "ignoreFailures": true
              },
              {
                "description": "Set Disassembly Flavor to Intel",
                "text": "-gdb-set disassembly-flavor intel",
                "ignoreFailures": true
              }
            ]
          },
          {
            "name": "Flexus Run Harness",
